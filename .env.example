NEXT_PUBLIC_WHATSAPP_NUMBER=254700000000
NEXT_PUBLIC_WHATSAPP_NUMBER_NAIROBI=254700000000
NEXT_PUBLIC_WHATSAPP_NUMBER_ACCRA=233500000000
NEXT_PUBLIC_CONTACT_EMAIL=hello@goldstay.co.ke
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
RESEND_API_KEY=
# Inbound routing. Each public form sends to a separate alias so tenant
# PII never commingles with landlord pipeline notes in a shared thread.
# All three aliases forward into the Goldstay Workspace mailbox; the
# split is organisational, not technical. LEAVE UNSET to fall back to the
# hardcoded defaults below (which already point at the correct aliases).
#
#   Landlord enquiries   (/list-your-property)  -> leads@goldstay.co.ke
#   Tenant waitlist      (/find-a-home)         -> tenants@goldstay.co.ke
#   Tenant applications  (/apply, KYC + PDF)    -> ops@goldstay.co.ke
#
# CONTACT_INBOX and TENANT_OPS_INBOX are honoured as legacy fallbacks
# for existing Vercel deployments; prefer the *_INBOX names going forward.
LEADS_INBOX=leads@goldstay.co.ke
TENANTS_INBOX=tenants@goldstay.co.ke
OPS_INBOX=ops@goldstay.co.ke

# Outbound "From" identities. goldstay.co.ke is verified in Resend
# (SPF + DKIM live), so these sends are deliverable out of the box.
# Override only if you want a different display name per surface (e.g.
# "Goldstay Nairobi" vs "Goldstay Accra") or to send from a different
# verified sub-brand once goldstay.com.gh comes online.
RESEND_FROM_LEADS=Goldstay Leads <leads@goldstay.co.ke>
RESEND_FROM_TENANTS=Goldstay Tenants <tenants@goldstay.co.ke>
RESEND_FROM_OPS=Goldstay Ops <ops@goldstay.co.ke>

# Airtable CRM (optional). When both AIRTABLE_API_KEY and AIRTABLE_BASE_ID
# are set, every landlord lead and tenant application is also written to the
# configured Airtable base. If either is missing, email remains the only
# channel and the form still succeeds for the user. Use a Personal Access
# Token scoped to the single Goldstay base with data.records:write.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_LEADS_TABLE=Landlord leads
AIRTABLE_TENANTS_TABLE=Tenant Applications
AIRTABLE_VACANCY_TABLE=Vacancy Leads
AIRTABLE_UNITS_TABLE=Units
AIRTABLE_WAITLIST_TABLE=Tenant waitlist

# Private-link gate for /apply (the tenant application form).
# Ops shares invitation links as:
#   https://goldstay.co.ke/apply?key=YOUR_SECRET&property=...&ref=...
# The server compares the ?key value against APPLY_ACCESS_TOKEN. Generate
# one random string ("openssl rand -hex 24"), paste it here AND into the
# Vercel project env vars. Rotate any time to invalidate all outstanding
# invitations instantly.
APPLY_ACCESS_TOKEN=

# Upstash Redis for rate limiting the public API routes
# (/api/lead, /api/tenant-application, /api/tenant-waitlist,
# /api/units/search). Free-tier Upstash REST credentials work fine.
# If these are unset, rate limiting is disabled with a log warning on
# first request; set them before going live to real traffic.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry error + performance monitoring. The public DSN is safe to expose
# (it identifies the project, not a secret); server and edge runtimes
# both read it. Leave empty to disable all Sentry reporting. SENTRY_ORG
# and SENTRY_PROJECT identify the Sentry workspace for source map upload;
# SENTRY_AUTH_TOKEN must be a Vercel env var (never commit) and only
# needs to be set in the production/preview environments where we want
# source maps uploaded. Without the auth token, builds still succeed,
# stack traces just don't symbolicate back to TS.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
