# Airtable CRM (optional). When both AIRTABLE_API_KEY and AIRTABLE_BASE_ID
# are set, every landlord lead and tenant application is also written to the
# configured Airtable base. If either is missing, email remains the only
# channel and the form still succeeds for the user. Use a Personal Access
# Token scoped to the single Goldstay base with data.records:write.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_LEADS_TABLE=Leads
AIRTABLE_TENANTS_TABLE=Tenant Applications
AIRTABLE_VACANCY_TABLE=Vacancy Leads
