// Goldstay platform schema.
//
// Single Postgres database hosted on Supabase. Multi-country support is
// expressed via the `country` enum on Property (and indirectly on every
// child entity through the property relation). Owner is the principal
// entity that authenticates against Supabase Auth; `authUserId` is the
// Supabase user id (uuid) and is the join key used everywhere we filter
// data per logged-in landlord.
//
// CRM data (leads, tenant applications, vacancy enquiries) intentionally
// stays in Airtable. Postgres holds product data only: who owns what,
// what is rented, what was paid, and which documents back it up.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Country {
  KE
  GH
}

enum PropertyStatus {
  ACTIVE
  ONBOARDING
  EXITED
}

enum UnitStatus {
  VACANT
  OCCUPIED
  RENOVATION
  OFF_MARKET
}

enum LeaseStatus {
  ACTIVE
  ENDED
  TERMINATED
  PENDING
}

enum TransactionType {
  RENT
  DEPOSIT
  REFUND
  EXPENSE
  MANAGEMENT_FEE
  PAYOUT
  OTHER
}

enum TransactionDirection {
  INFLOW
  OUTFLOW
}

enum DocumentKind {
  TITLE_DEED
  SALE_AGREEMENT
  LEASE
  KYC
  INVOICE
  RECEIPT
  STATEMENT
  PHOTO
  OTHER
}

// One row per landlord. authUserId is the Supabase auth.users.id so we
// can match a logged-in session straight back to a Goldstay owner. An
// owner can be a natural person or a company; we capture both shapes
// in a single denormalised row to keep the early product simple.
model Owner {
  id             String     @id @default(cuid())
  authUserId     String?    @unique
  email          String     @unique
  fullName       String
  phone          String?
  companyName    String?
  country        Country
  preferredCurrency String  @default("USD")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  properties     Property[]

  @@index([country])
}

model Property {
  id            String         @id @default(cuid())
  ownerId       String
  owner         Owner          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  country       Country
  city          String
  neighbourhood String?
  address       String
  name          String
  description   String?
  bedrooms      Int?
  bathrooms     Int?
  sizeSqm       Int?
  acquiredOn    DateTime?
  acquisitionPrice Decimal?    @db.Decimal(14, 2)
  acquisitionCurrency String?  @default("USD")
  status        PropertyStatus @default(ONBOARDING)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  units         Unit[]
  documents     Document[]
  valuations    Valuation[]
  transactions  Transaction[]

  @@index([ownerId])
  @@index([country])
}

model Unit {
  id          String      @id @default(cuid())
  propertyId  String
  property    Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  label       String
  bedrooms    Int?
  bathrooms   Int?
  sizeSqm     Int?
  status      UnitStatus  @default(VACANT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  leases      Lease[]

  @@index([propertyId])
}

model Lease {
  id           String      @id @default(cuid())
  unitId       String
  unit         Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenantName   String
  tenantEmail  String?
  tenantPhone  String?
  startDate    DateTime
  endDate      DateTime?
  monthlyRent  Decimal     @db.Decimal(12, 2)
  currency     String      @default("KES")
  depositAmount Decimal?   @db.Decimal(12, 2)
  status       LeaseStatus @default(ACTIVE)
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  transactions Transaction[]

  @@index([unitId])
  @@index([status])
}

model Transaction {
  id          String               @id @default(cuid())
  propertyId  String
  property    Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leaseId     String?
  lease       Lease?               @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  occurredOn  DateTime
  type        TransactionType
  direction   TransactionDirection
  amount      Decimal              @db.Decimal(12, 2)
  currency    String               @default("KES")
  description String?
  reference   String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([propertyId, occurredOn])
  @@index([leaseId])
}

// Snapshot of an estimated property valuation at a point in time.
// Multiple snapshots per property build the value-over-time chart in
// the owner dashboard. Source is a free-text label ("Knight Frank",
// "Goldstay internal", "Hass Index") so we don't lock the schema in.
model Valuation {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  valuedOn    DateTime
  amount      Decimal  @db.Decimal(14, 2)
  currency    String   @default("USD")
  source      String?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([propertyId, valuedOn])
}

model Document {
  id          String       @id @default(cuid())
  propertyId  String
  property    Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  kind        DocumentKind
  title       String
  storagePath String
  mimeType    String?
  sizeBytes   Int?
  uploadedBy  String?
  createdAt   DateTime     @default(now())

  @@index([propertyId, kind])
}
